# Server
NODE_ENV=production
PORT=4000
FRONTEND_URL=http://localhost:5173

# Database (overridden by docker-compose environment block)
DATABASE_URL=postgresql://aitudesk_user:aitudesk_super_secret_2024@postgres:5432/aitudesk?schema=public

# JWT
JWT_SECRET=aitudesk_jwt_super_secret_key_change_in_production
JWT_REFRESH_SECRET=aitudesk_refresh_super_secret_key_change_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10
MAX_FILES_PER_TICKET=5

# Seed Credentials
SEED_ADMIN_PASSWORD=Admin123!
SEED_AGENT_PASSWORD=Agent123!
SEED_USER_PASSWORD=User123!

# AI Assistant (OpenAI-compatible provider)
# Сейчас: Groq (llama-3.3-70b).  Чтобы переключиться на другого провайдера,
# поменяй AI_API_KEY, AI_BASE_URL и AI_MODEL — код в src/routes/ai.ts
# использует OpenAI SDK с произвольным baseURL.
AI_API_KEY=your_groq_api_key_here
AI_BASE_URL=https://api.groq.com/openai/v1
AI_MODEL=llama-3.3-70b-versatile
