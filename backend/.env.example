# Runtime
NODE_ENV=production
# Render sets PORT automatically. Use PORT=4000 only for local non-Docker runs.
# PORT=4000

# PostgreSQL (Neon)
# Use a Neon PostgreSQL connection string with sslmode=require.
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require

# Auth
# Generate strong values in Render. Do not commit real secrets.
JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS / cookies / Socket.IO
# Set these to your deployed frontend URL after Vercel deploy.
FRONTEND_URL=https://your-frontend.vercel.app
CORS_ORIGIN=https://your-frontend.vercel.app
# Optional comma-separated extra origins.
EXTRA_CORS_ORIGINS=

# Uploads
# Render free filesystem is ephemeral. Files may disappear after redeploy/restart.
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10
MAX_FILES_PER_TICKET=5

# Seed accounts
SEED_ADMIN_PASSWORD=Admin123!
SEED_AGENT_PASSWORD=Agent123!
SEED_USER_PASSWORD=User123!

# AI Assistant (optional, OpenAI-compatible provider)
AI_API_KEY=
AI_BASE_URL=https://api.groq.com/openai/v1
AI_MODEL=llama-3.3-70b-versatile
